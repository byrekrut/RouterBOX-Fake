# Domains for the delend.space deployment.
ROUTERBOX_DOMAIN=delend.space
ROUTEBOX_PANEL_DOMAIN=panel.delend.space

# Let's Encrypt contact email for the RouteBox panel.
ROUTEBOX_EMAIL=admin@delend.space

# Installation roots.
INSTALL_ROOT=/opt/routerbox-fake
CONFIG_DIR=/etc/routerbox-fake

# Upstream repositories and branches.
MYFAKESITE_REPO=https://github.com/iqubik/myfakesite.git
MYFAKESITE_BRANCH=main
ROUTEBOX_REPO=https://github.com/hoaxisr/routebox.git
ROUTEBOX_BRANCH=main

# RouteBox panel HTTPS port.
ROUTEBOX_PANEL_PORT=8443

# Set to 1 to use Let's Encrypt staging for RouteBox certificate tests.
ROUTEBOX_STAGING=0

# Set to 1 only if the upstream RouteBox repository provides a compatible vps-install.sh.
ROUTEBOX_USE_UPSTREAM_INSTALLER=0
